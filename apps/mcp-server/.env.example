# Database (shared with web app)
DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/agentvault

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# Next.js web app URL (for OAuth endpoints)
NEXT_APP_URL=http://localhost:3000

# Public URL where this MCP server is accessible
# For production: set to your subdomain (e.g., https://mcp.yourdomain.com)
# For local dev: leave unset to auto-detect from request headers
# MCP_PUBLIC_URL=https://mcp.yourdomain.com

# Server port
PORT=3001

# Blockchain chain ID (296 = Hedera testnet, 295 = Hedera mainnet)
CHAIN_ID=296

# RSA private key for decrypting session keys (same key as web app)
# Optional provider mode: `env` or `file` (defaults to env)
# SERVER_KEYS_PROVIDER=env
# If using file mode:
# SERVER_PRIVATE_KEY_PATH=/absolute/path/to/private.pem
# Generate with: pnpm --filter web generate-keys
SERVER_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# OAuth client credentials for the MCP platform
# These are generated when the platform client is registered
MCP_CLIENT_ID=agentvault-mcp-platform
MCP_CLIENT_SECRET=your_mcp_client_secret

# Shared bearer secret for MCP -> web internal execution calls
INTERNAL_SERVICE_SECRET=your_shared_internal_service_secret

# Debug logging for workflow execution (optional)
# WORKFLOW_DEBUG=true

# AgentDelegator contract address (for payment execution)
AGENT_DELEGATOR_ADDRESS=0x624f7c953dac044f3a38e7230c16f410cf7301d2

# Payment token address (USDC on Hedera testnet)
PAYMENT_TOKEN_ADDRESS=0x0673e78ccb1a401575f3514ddc920dabbdb3b3dd

# HCS Audit Trail (Hedera Consensus Service)
# Get operator credentials from https://portal.hedera.com/
# HCS_OPERATOR_ID=0.0.XXXXX
# HCS_OPERATOR_KEY=302e...
# HCS_TOPIC_ID=0.0.XXXXX
HCS_NETWORK=testnet

# HCS-10 Agent Identity (Hashgraph Online)
# These are set after first registration (auto-created if not set)
# HCS10_INBOUND_TOPIC_ID=0.0.XXXXX
# HCS10_OUTBOUND_TOPIC_ID=0.0.XXXXX
# HCS10_PROFILE_TOPIC_ID=0.0.XXXXX
